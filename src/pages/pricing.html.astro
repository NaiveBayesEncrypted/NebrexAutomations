---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaButton from "../components/CtaButton.astro";
import PackageGrid from "../components/PackageGrid.astro";
import { canonical, graph, ogImage, organizationSchema, serviceSchema } from "../data/seo";

const pageUrl = canonical("/pricing.html");

const meta = {
  "title": "Nebrex Pricing & Packages for Calgary Small Businesses",
  "description": "Transparent Nebrex pricing for website, lead response, follow-up, Growth, and Partner packages built for Calgary small businesses.",
  "canonical": pageUrl,
  "ogTitle": "Nebrex Pricing & Packages for Calgary Small Businesses",
  "ogDescription": "Choose the Nebrex growth system that fits where your local business is today.",
  "ogUrl": pageUrl,
  "ogImage": ogImage,
  "jsonLd": graph([
    organizationSchema(),
    serviceSchema("Nebrex pricing and packages", "Website, lead response, follow-up, Growth, and Partner packages for Calgary small businesses.", pageUrl)
  ])
};
---

<BaseLayout {...meta}>
  <section class="hero solutions-hero">
    <div>
      <div class="eyebrow">Packages</div>
      <h1>Choose the system that fits your business today</h1>
      <p>Start with a better website, faster lead response, stronger follow-up, or Nebrex Growth to bring the pieces together.</p>
      <div class="cta-row"><CtaButton /></div>
    </div>
    <div class="hero-card">
      <h3>Package principles</h3>
      <ul class="hero-list">
        <li>Clear outcome by package</li>
        <li>Simple starting point</li>
        <li>Built for local businesses</li>
        <li>Easy to expand over time</li>
      </ul>
    </div>
  </section>

  <section>
    <div class="section-title">Packages</div>
    <h2>Simple systems for growing local businesses</h2>
    <p class="section-sub">Choose the package that fits your business today. Start simple, then expand over time.</p>
    <PackageGrid />
  </section>

  <section>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <h3>Start simple and build from there</h3>
          <p class="section-sub">If you are not sure where to start, book a call and we will help you choose the package that matches the biggest gap in your business today.</p>
        </div>
        <div class="cta-row"><CtaButton /></div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-title">Package pages</div>
    <h2>Compare each system in more detail</h2>
    <div class="grid-3">
      <a class="card" href="/packages/presence/"><h4>Nebrex Presence</h4><p>Website-first foundation for credibility, service clarity, and local SEO basics.</p></a>
      <a class="card" href="/packages/capture/"><h4>Nebrex Capture</h4><p>Chatbot, lead capture, missed-call text back, and qualification.</p></a>
      <a class="card" href="/packages/flow/"><h4>Nebrex Flow</h4><p>Follow-up automation for quotes, reminders, updates, and reviews.</p></a>
      <a class="card" href="/packages/growth/"><h4>Nebrex Growth</h4><p>The connected website, lead flow, and follow-up package.</p></a>
      <a class="card" href="/packages/partner/"><h4>Nebrex Partner</h4><p>Ongoing support, refinement, reporting review, and priority help.</p></a>
    </div>
  </section>
</BaseLayout>
