---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaButton from "../components/CtaButton.astro";
import PackageGrid from "../components/PackageGrid.astro";
import { addOns, packages } from "../data/packages";
import { canonical, graph, offerCatalogSchema, ogImage, organizationSchema, serviceSchema, webPageSchema } from "../data/seo";

const pageUrl = canonical("/services.html");

const meta = {
  "title": "Website & AI Automation Services for Calgary Businesses",
  "description": "Outcome-based website, AI chat, lead capture, follow-up, and automation services for Calgary small businesses that need simpler systems.",
  "canonical": pageUrl,
  "ogTitle": "Website & AI Automation Services for Calgary Businesses",
  "ogDescription": "Simple growth systems for local businesses: better website, faster response, better follow-up, and less manual work.",
  "ogUrl": pageUrl,
  "ogImage": ogImage,
  "jsonLd": graph([
    organizationSchema(),
    webPageSchema("Website & AI Automation Services for Calgary Businesses", "Outcome-based website, AI chat, lead capture, follow-up, and automation services for Calgary small businesses that need simpler systems.", pageUrl),
    serviceSchema("Website and AI automation services for Calgary small businesses", "Outcome-based website, AI chat, lead capture, follow-up, and automation systems for Calgary small businesses.", pageUrl),
    offerCatalogSchema("Nebrex service systems", "Outcome-based website, lead response, follow-up, Growth, and Partner systems for local businesses.", pageUrl, packages)
  ])
};
---

<BaseLayout {...meta}>
  <section class="hero solutions-hero">
    <div>
      <div class="eyebrow">Services</div>
      <h1>Simple business systems, not random services</h1>
      <p>Nebrex combines websites, AI chat, lead capture, follow-up, and simple automation into systems that help local businesses win more business.</p>
      <div class="cta-row"><a class="btn btn-primary" href="#packages">See Packages</a><CtaButton class="btn btn-outline" /></div>
    </div>
    <div class="hero-card">
      <h3>What the systems solve</h3>
      <ul class="hero-list">
        <li>Poor first impressions</li>
        <li>Slow lead response</li>
        <li>Weak follow-up</li>
        <li>Too much manual admin</li>
      </ul>
    </div>
  </section>

  <section id="packages">
    <div class="section-title">Packages</div>
    <h2>Simple systems for growing local businesses</h2>
    <p class="section-sub">Choose the package that fits your business today. Start simple, then expand over time.</p>
    <PackageGrid />
  </section>

  <section>
    <div class="section-title">How it works</div>
    <h2>Built around outcomes your business can feel</h2>
    <div class="grid-3">
      <div class="card"><h4>Better website</h4><p>Improve the first impression, explain your services clearly, and make it easier for customers to contact you.</p></div>
      <div class="card"><h4>Faster response</h4><p>Use chat, forms, alerts, and missed-call text back so more inquiries turn into real conversations.</p></div>
      <div class="card"><h4>Better follow-up</h4><p>Keep quotes, appointments, reviews, and customer updates moving without adding more manual work.</p></div>
    </div>
  </section>

  <section>
    <div class="section-title">Use cases</div>
    <h2>Built for common local-business workflows</h2>
    <div class="grid-3">
      <a class="card" href="/solutions/hvac/"><h4>HVAC companies</h4><p>Emergency call recovery, seasonal lead response, and quote follow-up.</p></a>
      <a class="card" href="/solutions/plumbing/"><h4>Plumbing companies</h4><p>Missed-call text back, urgent intake, and review request workflows.</p></a>
      <a class="card" href="/solutions/roofing/"><h4>Roofing companies</h4><p>Estimate request capture, storm demand intake, and follow-up.</p></a>
      <a class="card" href="/solutions/electrical/"><h4>Electrical companies</h4><p>Job-type qualification, dispatch handoff, and customer updates.</p></a>
    </div>
  </section>

  <section>
    <div class="section-title">Service areas</div>
    <h2>Calgary-first, with support for nearby businesses</h2>
    <p class="section-sub">Nebrex is built around Calgary small businesses first, with practical website, lead response, and follow-up support for nearby communities.</p>
    <div class="grid-3">
      <a class="card" href="/locations/airdrie/"><h4>Airdrie</h4><p>Service-area clarity, faster inquiry response, and simple systems for growing local teams.</p></a>
      <a class="card" href="/locations/cochrane/"><h4>Cochrane</h4><p>Local trust, mobile inquiry paths, and follow-up for quote-based businesses.</p></a>
      <a class="card" href="/locations/okotoks/"><h4>Okotoks</h4><p>Website clarity, lead capture, and appointment or quote follow-up systems.</p></a>
      <a class="card" href="/locations/chestermere/"><h4>Chestermere</h4><p>Local and Calgary-area positioning with chat, missed-call, and follow-up support.</p></a>
    </div>
  </section>

  <section>
    <div class="section-title">Add-ons</div>
    <h2>Expand when the core system is working</h2>
    <div class="grid-3">
      {addOns.map((item) => (
        <div class="card"><h4>{item}</h4><p>Add this when your business needs a more complete setup.</p></div>
      ))}
    </div>
    <div class="cta-row" style="margin-top:18px;"><CtaButton /></div>
  </section>
</BaseLayout>
