---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CtaButton from "../../../components/CtaButton.astro";

const meta = {
  "title": "HVAC Solutions | Nebrex Automations",
  "description": "Automation systems for HVAC lead response, dispatch readiness, and after-hours intake.",
  "canonical": "https://nebrex.ca/solutions/hvac/",
  "ogTitle": "HVAC Solutions | Nebrex Automations",
  "ogDescription": "Automation systems for HVAC lead response, dispatch readiness, and after-hours intake.",
  "ogUrl": "https://nebrex.ca/solutions/hvac/",
  "ogImage": "https://nebrex.ca/og-image.png",
  "jsonLd": ""
};
---

<BaseLayout {...meta}>

    <section class="hero solutions-hero">
      <div>
        <div class="eyebrow">Industry Solution</div>
        <h1>HVAC Solutions</h1>
        <p>Automation systems for HVAC lead response, dispatch readiness, and after-hours intake.</p>
        <div class="cta-row"><CtaButton /></div>
      </div>
      <div class="hero-card">
        <h3>What this includes</h3>
        <ul class="hero-list"><li>Emergency call recovery</li><li>Seasonal demand response</li><li>Quote follow-up for installs</li></ul>
      </div>
    </section>

    <section>
      <div class="section-title">Execution</div>
      <h2>How we deploy this for your team</h2>
      <div class="steps">
        <div class="step"><span class="step-number">1</span><span class="step-text">Audit current intake and follow-up bottlenecks.</span></div>
        <div class="step"><span class="step-number">2</span><span class="step-text">Build workflow logic and team handoff paths.</span></div>
        <div class="step"><span class="step-number">3</span><span class="step-text">Launch with KPI tracking and monthly optimization.</span></div>
      </div>
    </section>

    <section>
      <div class="section-title">Next Step</div>
      <h2>Get your custom rollout plan</h2>
      <p class="section-sub">We map the highest-impact workflow for your operation first.</p>
      <div class="cta-row"><CtaButton /></div>
    </section>
</BaseLayout>


