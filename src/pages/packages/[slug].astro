---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CtaButton from "../../components/CtaButton.astro";
import { packages } from "../../data/packages";
import { canonical, faqSchema, graph, ogImage, organizationSchema, serviceSchema } from "../../data/seo";

export function getStaticPaths() {
  return packages.map((pkg) => ({
    params: { slug: pkg.slug },
    props: { pkg }
  }));
}

const { pkg } = Astro.props;
const packagePath = `/packages/${pkg.slug}/`;
const pageUrl = canonical(packagePath);
const pageFaqs = pkg.faqs || [];
const relatedSolutions = pkg.relatedSolutions || [];

const meta = {
  title: pkg.seoTitle || `${pkg.name} | Nebrex Automations`,
  description: pkg.seoDescription || `${pkg.name}: ${pkg.description} Built for Calgary small businesses that want simple systems that actually get used.`,
  canonical: pageUrl,
  ogTitle: `${pkg.name} | Nebrex Automations`,
  ogDescription: pkg.seoDescription || pkg.description,
  ogUrl: pageUrl,
  ogImage,
  jsonLd: graph([
    organizationSchema(),
    serviceSchema(pkg.name, pkg.seoDescription || pkg.description, pageUrl),
    ...(pageFaqs.length ? [faqSchema(pageFaqs)] : [])
  ])
};
---

<BaseLayout {...meta}>
  <section class="hero solutions-hero">
    <div>
      <div class="eyebrow">Package</div>
      <h1>{pkg.name}</h1>
      <div class="package-price package-page-price" aria-label={pkg.price.label}>
        <span>{pkg.price.label}</span>
        <strong>{pkg.price.setup}</strong>
        <strong>{pkg.price.monthly}</strong>
      </div>
      <p>{pkg.description}</p>
      <div class="cta-row package-page-actions">
        {pkg.checkoutHref ? (
          <a class="btn btn-primary" href={pkg.checkoutHref}>{pkg.checkoutLabel}</a>
        ) : (
          <CtaButton />
        )}
        {pkg.checkoutHref && <CtaButton class="btn btn-outline" />}
        <a class="package-tertiary-link" href="/pricing.html">View all packages</a>
      </div>
    </div>
    <div class="hero-card">
      <h3>{pkg.focus}</h3>
      <ul class="hero-list">
        {pkg.outcomes.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section>
    <div class="section-title">What is included</div>
    <h2>A clear system your team can understand</h2>
    <p class="section-sub">Each package is built around practical outcomes, simple setup, and customer communication that feels natural for a local business.</p>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <h3>{pkg.name} includes</h3>
          <ul>
            {pkg.includes.map((item) => <li>{item}</li>)}
          </ul>
          <p class="package-scope-note package-page-note">Most projects stay close to these starting prices. Final pricing depends on page count, integrations, and workflow complexity.</p>
        </div>
        <div>
          <h3>Best for</h3>
          <p>{pkg.bestFor}</p>
          <div class="cta-row" style="margin-top:18px;"><CtaButton /></div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-title">Why it helps</div>
    <h2>Built to remove the gap, not add more complexity</h2>
    <div class="grid-3">
      {pkg.outcomes.map((item) => (
        <div class="card">
          <h4>{item}</h4>
          <p>Designed as part of a simple Nebrex system, so the improvement is easy to understand, use, and build on over time.</p>
        </div>
      ))}
    </div>
  </section>

  <section>
    <div class="section-title">Common problems</div>
    <h2>The business gap this package is built to fix</h2>
    <div class="grid-3">
      {pkg.problems.map((item) => (
        <div class="card">
          <h4>{item.split(" ").slice(0, 4).join(" ")}</h4>
          <p>{item}</p>
        </div>
      ))}
    </div>
  </section>

  <section>
    <div class="section-title">Implementation</div>
    <h2>How {pkg.name} rolls out</h2>
    <div class="steps">
      {pkg.implementation.map((item, index) => (
        <div class="step">
          <span class="step-number">{index + 1}</span>
          <span class="step-text">{item}</span>
        </div>
      ))}
    </div>
  </section>

  {relatedSolutions.length > 0 && (
    <section>
      <div class="section-title">Related paths</div>
      <h2>See where this package fits</h2>
      <div class="grid-3">
        {relatedSolutions.map((item) => (
          <a class="card" href={item.href}>
            <h4>{item.label}</h4>
            <p>Explore how this system applies to a specific business type or customer-flow problem.</p>
          </a>
        ))}
        <a class="card" href="/pricing.html">
          <h4>All packages</h4>
          <p>Compare Presence, Capture, Flow, Growth, and Partner before choosing the right starting point.</p>
        </a>
      </div>
    </section>
  )}

  {pageFaqs.length > 0 && (
    <section>
      <div class="section-title">FAQ</div>
      <h2>Questions about {pkg.name}</h2>
      <div class="faq">
        {pageFaqs.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  )}

  <section>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <div class="section-title">Next step</div>
          <h3>See if {pkg.name} fits your business.</h3>
          <p class="section-sub">We can help you choose the right starting point and map the simplest version to launch first.</p>
        </div>
        <div class="cta-row"><CtaButton /></div>
      </div>
    </div>
  </section>
</BaseLayout>
