---
import BaseLayout from "../layouts/BaseLayout.astro";
import { canonical, graph, ogImage, organizationSchema } from "../data/seo";

const pageUrl = canonical("/careers.html");
const careersEmail = "careers@nebrex.ca";
const applyHref = `mailto:${careersEmail}?subject=${encodeURIComponent("Sales Representative application - Nebrex")}`;

const roles = [
  {
    title: "Sales Representative - Digital AI Marketing",
    type: "Sales",
    href: "#sales-representative-digital-ai-marketing",
    summary: "Commission-only sales role helping local businesses adopt websites, ads, AI chat, AI receptionists, and lead capture systems.",
    location: "Remote",
    applySubject: "Sales Representative application - Nebrex"
  },
  {
    title: "Technical Implementation Specialist",
    type: "Tech",
    href: "#technical-implementation-specialist",
    summary: "Project-based technical role building practical website, chatbot, lead capture, and follow-up systems for small businesses.",
    location: "Remote-friendly, Calgary overlap preferred",
    applySubject: "Technical Implementation Specialist application - Nebrex"
  },
  {
    title: "Operations and Admin Coordinator",
    type: "Admin",
    href: "#operations-and-admin-coordinator",
    summary: "Part-time admin role supporting scheduling, client notes, task tracking, documentation, and follow-up coordination.",
    location: "Calgary-first, remote-friendly",
    applySubject: "Operations and Admin Coordinator application - Nebrex"
  }
];

const jobPostingSchemas = [
  {
  "@type": "JobPosting",
  title: "Sales Representative - Digital AI Marketing",
  description: "Nebrex is hiring a commission-only Sales Representative to sell websites, SEO, Google Ads, AI chatbots, lead capture landing pages, AI receptionists, Meta and Facebook Ads, website maintenance, and marketing video production to local businesses across Calgary and beyond.",
  datePosted: "2026-05-19",
  validThrough: "2026-07-31",
  employmentType: ["FULL_TIME", "PART_TIME", "CONTRACTOR"],
  directApply: true,
  hiringOrganization: {
    "@type": "Organization",
    name: "Nebrex Automations",
    sameAs: "https://nebrex.ca"
  },
  jobLocationType: "TELECOMMUTE",
  applicantLocationRequirements: {
    "@type": "Country",
    name: "Canada"
  },
  jobLocation: {
    "@type": "Place",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Calgary",
      addressRegion: "AB",
      addressCountry: "CA"
    }
  },
  baseSalary: {
    "@type": "MonetaryAmount",
    currency: "CAD",
    value: {
      "@type": "QuantitativeValue",
      minValue: 60000,
      maxValue: 120000,
      unitText: "YEAR"
    }
  }
  },
  {
    "@type": "JobPosting",
    title: "Technical Implementation Specialist",
    description: "Nebrex is hiring a Technical Implementation Specialist to build and support website updates, chatbot setup, lead forms, automation workflows, integrations, launch QA, and client documentation.",
    datePosted: "2026-05-20",
    validThrough: "2026-07-31",
    employmentType: ["CONTRACTOR", "PART_TIME"],
    directApply: true,
    hiringOrganization: {
      "@type": "Organization",
      name: "Nebrex Automations",
      sameAs: "https://nebrex.ca"
    },
    jobLocationType: "TELECOMMUTE",
    applicantLocationRequirements: {
      "@type": "Country",
      name: "Canada"
    }
  },
  {
    "@type": "JobPosting",
    title: "Operations and Admin Coordinator",
    description: "Nebrex is hiring an Operations and Admin Coordinator to support scheduling, inbox support, client notes, task tracking, simple reporting, onboarding admin, and follow-up reminders.",
    datePosted: "2026-05-20",
    validThrough: "2026-07-31",
    employmentType: ["PART_TIME", "CONTRACTOR"],
    directApply: true,
    hiringOrganization: {
      "@type": "Organization",
      name: "Nebrex Automations",
      sameAs: "https://nebrex.ca"
    },
    jobLocationType: "TELECOMMUTE",
    applicantLocationRequirements: {
      "@type": "Country",
      name: "Canada"
    }
  }
];

const meta = {
  title: "Careers at Nebrex | Sales, Tech & Admin Roles",
  description: "Nebrex is hiring for sales, technical implementation, and operations/admin roles supporting websites, ads, AI chat, AI receptionists, and automation systems.",
  canonical: pageUrl,
  ogTitle: "Careers at Nebrex | Sales, Tech & Admin Roles",
  ogDescription: "Join Nebrex and help local businesses adopt practical websites, lead capture, follow-up, ads, and AI automation systems.",
  ogUrl: pageUrl,
  ogImage,
  jsonLd: graph([organizationSchema(), ...jobPostingSchemas])
};
---

<BaseLayout {...meta}>
  <section class="hero solutions-hero" id="sales-representative-digital-ai-marketing">
    <div>
      <div class="eyebrow">Careers</div>
      <h1>Sales Representative - Digital AI Marketing</h1>
      <p>Nebrex is looking for driven, results-oriented sales professionals who want to help local businesses improve how they look online, capture more leads, and follow up faster using websites, ads, AI chat, and automation systems.</p>
      <div class="cta-row">
        <a class="btn" href={applyHref}>Apply by Email</a>
      </div>
    </div>
    <div class="hero-card">
      <h3>Role snapshot</h3>
      <ul class="hero-list">
        <li>Commission only</li>
        <li>Remote</li>
        <li>Full-time or part-time</li>
        <li>$60,000 - $120,000/year estimated earnings</li>
        <li>20 - 40 expected hours per week</li>
      </ul>
    </div>
  </section>

  <section>
    <div class="section-title">Open roles</div>
    <h2>Current Nebrex openings</h2>
    <p class="section-sub">We are hiring for sales, technical implementation, and operations support. Each role has a direct email application link so candidates can send a resume quickly.</p>
    <div class="grid-3">
      {roles.map((role) => (
        <a class="card" href={role.href}>
          <span class="problem-tag">{role.type}</span>
          <h4>{role.title}</h4>
          <p>{role.summary}</p>
          <p>{role.location}</p>
        </a>
      ))}
    </div>
  </section>

  <section>
    <div class="section-title">About Nebrex</div>
    <h2>Help local businesses stop missing leads</h2>
    <div class="offer">
      <p class="section-sub">Nebrex is a fast-growing digital AI marketing company helping local businesses across Calgary and beyond improve their market presence through practical technology. From AI-powered websites and Google Ads to AI receptionists that answer calls 24/7, Nebrex gives businesses the tools to capture leads, respond faster, and follow up more consistently.</p>
      <p class="section-sub">We are expanding our sales team and looking for professionals who are ready to bet on themselves, build a pipeline, and earn based on performance.</p>
    </div>
  </section>

  <section>
    <div class="section-title">The role</div>
    <h2>What you will do</h2>
    <div class="grid-3">
      <div class="card"><h4>Own the sales cycle</h4><p>Manage the process from first outreach through close, with clear notes and follow-up at every stage.</p></div>
      <div class="card"><h4>Prospect local businesses</h4><p>Work targeted leads and prospect small businesses across multiple industries.</p></div>
      <div class="card"><h4>Run demos</h4><p>Conduct product demos that show Nebrex websites, AI tools, ads, and automation systems in action.</p></div>
      <div class="card"><h4>Explain the value</h4><p>Articulate Nebrex clearly to business owners and decision-makers in practical business language.</p></div>
      <div class="card"><h4>Manage your pipeline</h4><p>Build and maintain an active pipeline using CRM tools and consistent follow-up.</p></div>
      <div class="card"><h4>Hit revenue targets</h4><p>Meet or exceed monthly and quarterly revenue goals while providing useful market feedback to leadership.</p></div>
    </div>
  </section>

  <section>
    <div class="section-title">Services</div>
    <h2>What you will be selling</h2>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <h3>Core offers</h3>
          <ul>
            <li>Website design, build, and maintenance</li>
            <li>Search Engine Optimization (SEO)</li>
            <li>Google Ads management</li>
            <li>AI chatbots and website live chat</li>
            <li>Meta and Facebook Ads</li>
          </ul>
        </div>
        <div>
          <h3>AI and lead systems</h3>
          <ul>
            <li>AI-powered lead capture landing pages</li>
            <li>AI Receptionist - voice agents that handle inbound and outbound calls on minute-based packages</li>
            <li>Marketing video production as an optional add-on for local businesses</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-title">Fit</div>
    <h2>What we are looking for</h2>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <h3>Experience</h3>
          <ul>
            <li>2+ years of B2B or direct sales experience</li>
            <li>SaaS, digital marketing, or tech sales experience is a strong asset</li>
            <li>Experience with CRM platforms such as GoHighLevel, HubSpot, Salesforce, or similar</li>
            <li>Familiarity with digital marketing concepts is a bonus, but not required</li>
          </ul>
        </div>
        <div>
          <h3>Working style</h3>
          <ul>
            <li>Comfortable and confident in a commission-only structure</li>
            <li>Self-starter who can manage schedule, pipeline, and follow-ups independently</li>
            <li>Strong communicator on video calls, written outreach, and live demos</li>
            <li>Consultative selling approach: listen first, then solve</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-title">Compensation</div>
    <h2>Commission-only with uncapped upside</h2>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <h3>Compensation and perks</h3>
          <ul>
            <li>Commission only - fully uncapped earnings</li>
            <li>Estimated annual earnings: $60,000 - $120,000+ based on performance</li>
            <li>Residual income: every client you sign pays you month after month for as long as they remain a Nebrex customer</li>
            <li>Leads and prospect lists provided so you can focus on selling</li>
            <li>Performance bonuses for top closers hitting key revenue milestones</li>
            <li>Fully remote work</li>
            <li>Growth opportunity as Nebrex scales</li>
          </ul>
        </div>
        <div>
          <h3>Why residual matters</h3>
          <p class="section-sub">Your income can grow and compound with every new client added to your book. Close once, earn indefinitely while the client remains with Nebrex.</p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-title">Who should apply</div>
    <h2>Be honest about the fit</h2>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <h3>This role is not for you if</h3>
          <ul>
            <li>You need a guaranteed base salary</li>
            <li>You are brand new to sales with no track record</li>
            <li>You are not comfortable owning your results independently</li>
          </ul>
        </div>
        <div>
          <h3>This is for you if</h3>
          <ul>
            <li>You are a closer who backs yourself</li>
            <li>You want to build a residual income stream</li>
            <li>You are hungry, coachable, and ready to grow with a company that is moving fast</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="technical-implementation-specialist">
    <div class="section-title">Tech role</div>
    <h2>Technical Implementation Specialist</h2>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <h3>Role summary</h3>
          <p class="section-sub">Build and support practical website, chatbot, lead capture, and follow-up systems for small businesses using clean, simple implementation.</p>
          <ul>
            <li>Remote-friendly, Calgary overlap preferred</li>
            <li>Contract or project-based to start</li>
            <li>Reports into Nebrex leadership as the company grows</li>
          </ul>
          <h3>What you will own</h3>
          <ul>
            <li>Website page updates and QA</li>
            <li>Chatbot and lead form setup</li>
            <li>Automation workflow configuration</li>
            <li>Integrations and testing</li>
            <li>Launch support and documentation</li>
          </ul>
        </div>
        <div>
          <h3>Who this is for</h3>
          <ul>
            <li>You care about clean customer experience, not just tools</li>
            <li>You can troubleshoot calmly and document what changed</li>
            <li>You understand websites, forms, automations, and basic integrations</li>
            <li>You can keep systems simple enough for small teams to use</li>
          </ul>
          <h3>Success looks like</h3>
          <ul>
            <li>Working client systems</li>
            <li>Clear launch checklists</li>
            <li>Reliable forms, alerts, and follow-up flows</li>
            <li>Useful notes for ongoing support</li>
          </ul>
          <div class="cta-row">
            <a class="btn" href={`mailto:${careersEmail}?subject=${encodeURIComponent("Technical Implementation Specialist application - Nebrex")}`}>Apply for this role</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="operations-and-admin-coordinator">
    <div class="section-title">Admin role</div>
    <h2>Operations and Admin Coordinator</h2>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <h3>Role summary</h3>
          <p class="section-sub">Keep Nebrex organized behind the scenes by supporting client communication, scheduling, task tracking, documentation, and follow-up.</p>
          <ul>
            <li>Calgary-first, remote-friendly</li>
            <li>Part-time to start</li>
            <li>Reports into Nebrex leadership as the company grows</li>
          </ul>
          <h3>What you will own</h3>
          <ul>
            <li>Scheduling and inbox support</li>
            <li>Client notes and task tracking</li>
            <li>Simple reporting snapshots</li>
            <li>Proposal and onboarding admin</li>
            <li>Follow-up reminders and internal coordination</li>
          </ul>
        </div>
        <div>
          <h3>Who this is for</h3>
          <ul>
            <li>You are organized, careful, and reliable</li>
            <li>You write clearly and keep details tidy</li>
            <li>You like improving small processes</li>
            <li>You can help a fast-moving team stay calm and consistent</li>
          </ul>
          <h3>Success looks like</h3>
          <ul>
            <li>Cleaner client communication</li>
            <li>Fewer missed internal steps</li>
            <li>Updated task lists and records</li>
            <li>More consistent operations support</li>
          </ul>
          <div class="cta-row">
            <a class="btn" href={`mailto:${careersEmail}?subject=${encodeURIComponent("Operations and Admin Coordinator application - Nebrex")}`}>Apply for this role</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <div class="section-title">Apply</div>
          <h3>Send your resume and cover letter.</h3>
          <p class="section-sub">To apply, email your resume and cover letter to <a href={applyHref}>{careersEmail}</a>. Use the subject line: Sales Representative application - Nebrex.</p>
        </div>
        <div class="cta-row">
          <a class="btn" href={applyHref}>Email Your Resume</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
