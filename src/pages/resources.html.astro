---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaButton from "../components/CtaButton.astro";
import { canonical, graph, ogImage, organizationSchema, resourceArticles } from "../data/seo";

const pageUrl = canonical("/resources.html");

const meta = {
  "title": "Small Business Growth Resources | Nebrex Calgary",
  "description": "Practical guides for Calgary small businesses improving websites, lead response, AI chat, missed calls, follow-up, and automation.",
  "canonical": pageUrl,
  "ogTitle": "Small Business Growth Resources | Nebrex Calgary",
  "ogDescription": "Practical resources for local businesses that want better websites, faster replies, and better follow-up.",
  "ogUrl": pageUrl,
  "ogImage": ogImage,
  "jsonLd": graph([organizationSchema()])
};
---

<BaseLayout {...meta}>
  <section class="hero solutions-hero">
    <div>
      <div class="eyebrow">Resources</div>
      <h1>Practical guides for local business growth</h1>
      <p>Use these resources to improve your website, respond faster, follow up better, and reduce manual admin.</p>
      <div class="cta-row"><CtaButton /></div>
    </div>
    <div class="hero-card">
      <h3>Read first</h3>
      <ul class="hero-list">
        <li>How to tell if your website is costing you leads</li>
        <li>Simple lead response checklist</li>
        <li>Follow-up system for small businesses</li>
        <li>What to automate first</li>
      </ul>
    </div>
  </section>

  <section>
    <div class="section-title">Featured Articles</div>
    <h2>Simple playbooks for better customer flow</h2>
    <div class="grid-3">
      {resourceArticles.map((article) => (
        <a class="card" href={`/resources/${article.slug}/`}>
          <h4>{article.title}</h4>
          <p>{article.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section>
    <div class="offer">
      <div class="offer-grid">
        <div>
          <div class="section-title">Next step</div>
          <h3>Want help applying this to your business?</h3>
          <p class="section-sub">Book a call and we will help you choose the simplest Nebrex system to start with.</p>
        </div>
        <div class="cta-row"><CtaButton /></div>
      </div>
    </div>
  </section>
</BaseLayout>
